<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/wave_background"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="24dp"
        android:paddingTop="28dp"
        android:paddingRight="24dp"
        android:paddingBottom="18dp">

        <ImageView
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:contentDescription="@string/app_name"
            android:src="@drawable/wave_logo" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="14dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/wave_tagline"
                android:textColor="#AEB9CE"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:letterSpacing="0.18" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingLeft="20dp"
        android:paddingRight="20dp">

        <ScrollView
            android:id="@+id/page_dashboard"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="28dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginRight="10dp"
                        android:layout_weight="1"
                        android:background="@drawable/surface_card"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Session Hits"
                            android:textColor="#98A6C4"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/stat_hits_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:textColor="#FFFFFF"
                            android:textSize="28sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="10dp"
                        android:layout_weight="1"
                        android:background="@drawable/surface_card"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tracks Ready"
                            android:textColor="#98A6C4"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/stat_tracks_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:textColor="#FFFFFF"
                            android:textSize="28sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/surface_card"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Current Mode"
                        android:textColor="#98A6C4"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/stat_mix_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textColor="#FFFFFF"
                        android:textSize="26sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="Next cue"
                        android:textColor="#98A6C4"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/dashboard_cue_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="#E5ECFA"
                        android:textSize="18sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:orientation="vertical">

                    <Button
                        android:id="@+id/open_decks_button"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/accent_button"
                        android:text="Open Deck Control"
                        android:textAllCaps="false"
                        android:textColor="#05070B" />

                    <Button
                        android:id="@+id/open_pads_button"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/subtle_button"
                        android:text="Launch Performance Pads"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF" />

                    <Button
                        android:id="@+id/open_setlist_button"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/subtle_button"
                        android:text="Edit Tonight’s Setlist"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF" />

                    <Button
                        android:id="@+id/reset_session_button"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/nav_inactive_background"
                        android:text="Reset Live Session"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <ScrollView
            android:id="@+id/page_decks"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="28dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/surface_card"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Deck A BPM"
                        android:textColor="#98A6C4"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/deck_a_minus"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:background="@drawable/subtle_button"
                            android:text="−"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF"
                            android:textSize="24sp" />

                        <TextView
                            android:id="@+id/deck_a_bpm"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="24dp"
                            android:layout_marginRight="24dp"
                            android:textColor="#FFFFFF"
                            android:textSize="34sp"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/deck_a_plus"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:background="@drawable/accent_button"
                            android:text="+"
                            android:textAllCaps="false"
                            android:textColor="#05070B"
                            android:textSize="24sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/surface_card"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Deck B BPM"
                        android:textColor="#98A6C4"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/deck_b_minus"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:background="@drawable/subtle_button"
                            android:text="−"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF"
                            android:textSize="24sp" />

                        <TextView
                            android:id="@+id/deck_b_bpm"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="24dp"
                            android:layout_marginRight="24dp"
                            android:textColor="#FFFFFF"
                            android:textSize="34sp"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/deck_b_plus"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:background="@drawable/accent_button"
                            android:text="+"
                            android:textAllCaps="false"
                            android:textColor="#05070B"
                            android:textSize="24sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/surface_card"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Crossfader"
                        android:textColor="#98A6C4"
                        android:textSize="12sp" />

                    <SeekBar
                        android:id="@+id/crossfader_seek"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:max="100" />

                    <TextView
                        android:id="@+id/crossfader_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/surface_card"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Energy Profile"
                        android:textColor="#98A6C4"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/mode_warm"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginRight="8dp"
                            android:layout_weight="1"
                            android:text="Warm Up"
                            android:textAllCaps="false" />

                        <Button
                            android:id="@+id/mode_peak"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="4dp"
                            android:layout_marginRight="4dp"
                            android:layout_weight="1"
                            android:text="Peak"
                            android:textAllCaps="false" />

                        <Button
                            android:id="@+id/mode_late"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="8dp"
                            android:layout_weight="1"
                            android:text="Late Glow"
                            android:textAllCaps="false" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <ScrollView
            android:id="@+id/page_pads"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="28dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/surface_card"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pad Hits"
                        android:textColor="#98A6C4"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/pad_hits_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textColor="#FFFFFF"
                        android:textSize="30sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="Last Trigger"
                        android:textColor="#98A6C4"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/last_pad_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp" />
                </LinearLayout>

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:columnCount="2"
                    android:rowCount="4">

                    <Button android:id="@+id/pad_1" style="@style/Widget.AppCompat.Button.Borderless" android:layout_width="0dp" android:layout_height="116dp" android:layout_columnWeight="1" android:layout_margin="8dp" android:background="@drawable/pad_button_background" android:text="Kick" android:textAllCaps="false" android:textColor="#FFFFFF" />
                    <Button android:id="@+id/pad_2" style="@style/Widget.AppCompat.Button.Borderless" android:layout_width="0dp" android:layout_height="116dp" android:layout_columnWeight="1" android:layout_margin="8dp" android:background="@drawable/pad_button_background" android:text="Snare" android:textAllCaps="false" android:textColor="#FFFFFF" />
                    <Button android:id="@+id/pad_3" style="@style/Widget.AppCompat.Button.Borderless" android:layout_width="0dp" android:layout_height="116dp" android:layout_columnWeight="1" android:layout_margin="8dp" android:background="@drawable/pad_button_background" android:text="Clap" android:textAllCaps="false" android:textColor="#FFFFFF" />
                    <Button android:id="@+id/pad_4" style="@style/Widget.AppCompat.Button.Borderless" android:layout_width="0dp" android:layout_height="116dp" android:layout_columnWeight="1" android:layout_margin="8dp" android:background="@drawable/pad_button_background" android:text="Hat" android:textAllCaps="false" android:textColor="#FFFFFF" />
                    <Button android:id="@+id/pad_5" style="@style/Widget.AppCompat.Button.Borderless" android:layout_width="0dp" android:layout_height="116dp" android:layout_columnWeight="1" android:layout_margin="8dp" android:background="@drawable/pad_button_background" android:text="Bass" android:textAllCaps="false" android:textColor="#FFFFFF" />
                    <Button android:id="@+id/pad_6" style="@style/Widget.AppCompat.Button.Borderless" android:layout_width="0dp" android:layout_height="116dp" android:layout_columnWeight="1" android:layout_margin="8dp" android:background="@drawable/pad_button_background" android:text="Vox" android:textAllCaps="false" android:textColor="#FFFFFF" />
                    <Button android:id="@+id/pad_7" style="@style/Widget.AppCompat.Button.Borderless" android:layout_width="0dp" android:layout_height="116dp" android:layout_columnWeight="1" android:layout_margin="8dp" android:background="@drawable/pad_button_background" android:text="FX" android:textAllCaps="false" android:textColor="#FFFFFF" />
                    <Button android:id="@+id/pad_8" style="@style/Widget.AppCompat.Button.Borderless" android:layout_width="0dp" android:layout_height="116dp" android:layout_columnWeight="1" android:layout_margin="8dp" android:background="@drawable/pad_button_background" android:text="Loop" android:textAllCaps="false" android:textColor="#FFFFFF" />
                </GridLayout>
            </LinearLayout>
        </ScrollView>

        <ScrollView
            android:id="@+id/page_setlist"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="28dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/surface_card"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <EditText
                        android:id="@+id/track_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/nav_inactive_background"
                        android:hint="Add opener, switch-up, or closer"
                        android:padding="14dp"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#75819A" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/add_track_button"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginRight="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/accent_button"
                            android:text="Add Track"
                            android:textAllCaps="false"
                            android:textColor="#05070B" />

                        <Button
                            android:id="@+id/clear_setlist_button"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/subtle_button"
                            android:text="Clear"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/surface_card"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Booth Notes"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/notes_input"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/nav_inactive_background"
                        android:gravity="top"
                        android:hint="Write transitions, drops, or reminders"
                        android:inputType="textMultiLine"
                        android:padding="14dp"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#75819A" />

                    <Button
                        android:id="@+id/save_notes_button"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/subtle_button"
                        android:text="Save Notes"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF" />

                    <TextView
                        android:id="@+id/notes_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textColor="#98A6C4"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/setlist_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:orientation="vertical" />
            </LinearLayout>
        </ScrollView>
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingLeft="16dp"
        android:paddingTop="14dp"
        android:paddingRight="16dp"
        android:paddingBottom="20dp">

        <TextView android:id="@+id/nav_dashboard" android:layout_width="0dp" android:layout_height="48dp" android:layout_margin="6dp" android:layout_weight="1" android:background="@drawable/nav_inactive_background" android:gravity="center" android:text="Home" android:textColor="#98A6C4" />
        <TextView android:id="@+id/nav_decks" android:layout_width="0dp" android:layout_height="48dp" android:layout_margin="6dp" android:layout_weight="1" android:background="@drawable/nav_inactive_background" android:gravity="center" android:text="Decks" android:textColor="#98A6C4" />
        <TextView android:id="@+id/nav_pads" android:layout_width="0dp" android:layout_height="48dp" android:layout_margin="6dp" android:layout_weight="1" android:background="@drawable/nav_inactive_background" android:gravity="center" android:text="Pads" android:textColor="#98A6C4" />
        <TextView android:id="@+id/nav_setlist" android:layout_width="0dp" android:layout_height="48dp" android:layout_margin="6dp" android:layout_weight="1" android:background="@drawable/nav_inactive_background" android:gravity="center" android:text="Setlist" android:textColor="#98A6C4" />
    </LinearLayout>

</LinearLayout>